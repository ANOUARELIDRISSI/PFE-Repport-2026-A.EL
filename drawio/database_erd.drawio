        </mxCell>
        <mxCell id="erd-title" value="&lt;b&gt;Physical Persistence Schema&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#64748b&quot;&gt;MongoDB stores source evidence, derived analytical records, runtime state, and retrieval chunks; Neo4j and ZVec complement it with graph topology and vector search.&lt;/font&gt;" style="html=1;whiteSpace=wrap;fontFamily=Arial;verticalAlign=middle;text;strokeColor=none;fillColor=none;align=center;fontSize=25;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="0" y="30" width="1800" height="92" as="geometry"/>
        </mxCell>
        <mxCell id="documents-table" value="&lt;b&gt;documents&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#64748b&quot;&gt;source collection and pipeline checkpoint state&lt;/font&gt;&lt;hr&gt;- PKid unique sparse&lt;br&gt;- title, content, source_url&lt;br&gt;- source, source_name, published_date&lt;br&gt;- graph_extracted, structured_extracted&lt;br&gt;- chunks_created, quality_score" style="html=1;whiteSpace=wrap;fontFamily=Arial;verticalAlign=middle;rounded=1;arcSize=8;fillColor=#ffffff;strokeColor=#64748b;strokeWidth=2;align=left;spacing=12;fontSize=12;fontColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="725" y="170" width="350" height="255" as="geometry"/>
        </mxCell>
        <mxCell id="mentions-table" value="&lt;b&gt;entity_mentions&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#64748b&quot;&gt;one entity occurrence per document&lt;/font&gt;&lt;hr&gt;- IXentity_id&lt;br&gt;- FKdocument_id&lt;br&gt;- entity_name, entity_type&lt;br&gt;- source_name, published_date&lt;br&gt;- created_at" style="html=1;whiteSpace=wrap;fontFamily=Arial;verticalAlign=middle;rounded=1;arcSize=8;fillColor=#ffffff;strokeColor=#64748b;strokeWidth=2;align=left;spacing=12;fontSize=12;fontColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="175" y="170" width="292" height="255" as="geometry"/>
        </mxCell>
        <mxCell id="relations-table" value="&lt;b&gt;relation_assertions&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#64748b&quot;&gt;relation evidence mirrored from graph extraction&lt;/font&gt;&lt;hr&gt;- IXfrom_entity_id, to_entity_id&lt;br&gt;- relation_type, confidence&lt;br&gt;- evidence, status&lt;br&gt;- source_doc_ids, created_at" style="html=1;whiteSpace=wrap;fontFamily=Arial;verticalAlign=middle;rounded=1;arcSize=8;fillColor=#ffffff;strokeColor=#64748b;strokeWidth=2;align=left;spacing=12;fontSize=12;fontColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="175" y="520" width="292" height="255" as="geometry"/>
        </mxCell>
        <mxCell id="chunks-table" value="&lt;b&gt;document_chunks&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#64748b&quot;&gt;semantic retrieval units stored in MongoDB&lt;/font&gt;&lt;hr&gt;- PKchunk_id unique sparse&lt;br&gt;- FKdocument_id&lt;br&gt;- chunk_text, enriched_text&lt;br&gt;- chunk_index, section_header&lt;br&gt;- entity_ids, source_name" style="html=1;whiteSpace=wrap;fontFamily=Arial;verticalAlign=middle;rounded=1;arcSize=8;fillColor=#ffffff;strokeColor=#64748b;strokeWidth=2;align=left;spacing=12;fontSize=12;fontColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="632" y="660" width="292" height="255" as="geometry"/>
        </mxCell>
        <mxCell id="vectors-table" value="&lt;b&gt;ZVec vectors&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#64748b&quot;&gt;external vector index, not a MongoDB collection&lt;/font&gt;&lt;hr&gt;- PKchunk_id&lt;br&gt;- embedding, content&lt;br&gt;- metadata.document_id&lt;br&gt;- metadata.entity_ids&lt;br&gt;- metadata.published_date" style="html=1;whiteSpace=wrap;fontFamily=Arial;verticalAlign=middle;rounded=1;arcSize=8;fillColor=#ffffff;strokeColor=#64748b;strokeWidth=2;align=left;spacing=12;fontSize=12;fontColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="1010" y="660" width="292" height="255" as="geometry"/>
        </mxCell>
        <mxCell id="structured-table" value="&lt;b&gt;structured records&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#64748b&quot;&gt;MongoDB analytical collections from extraction step 2&lt;/font&gt;&lt;hr&gt;- bills: id, status, chamber&lt;br&gt;- votes: id, bill_id, date&lt;br&gt;- committees: id, chamber&lt;br&gt;- contributions: donor_id, recipient_id&lt;br&gt;- conflict_flags: severity, created_at" style="html=1;whiteSpace=wrap;fontFamily=Arial;verticalAlign=middle;rounded=1;arcSize=8;fillColor=#ffffff;strokeColor=#64748b;strokeWidth=2;align=left;spacing=12;fontSize=12;fontColor=#0f172a;" vertex="1" parent="1">
