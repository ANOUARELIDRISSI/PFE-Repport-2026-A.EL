        <mxCell id="seq-title" parent="1" style="html=1;whiteSpace=wrap;fontFamily=Arial;verticalAlign=middle;text;strokeColor=none;fillColor=none;align=center;fontSize=24;fontStyle=1;fontColor=#0f172a;" value="&lt;b&gt;Reasoning Execution Sequence&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#64748b&quot;&gt;The runtime query path adapts to the selected mode: strict RAG uses semantic retrieval, while Chain-of-Thought and Reflexive modes add planning, graph expansion, domain searches, and optional audit hops.&lt;/font&gt;" vertex="1">
          <mxGeometry height="92" width="1800" y="30" as="geometry" />
        </mxCell>
        <mxCell id="seq-api" parent="1" style="html=1;whiteSpace=wrap;fontFamily=Arial;verticalAlign=middle;rounded=1;arcSize=10;fillColor=#ffffff;strokeColor=#64748b;strokeWidth=2;align=center;spacing=10;fontSize=18;fontColor=#0f172a;shadow=0;" value="&lt;b&gt;1. Query Request&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#475569&quot;&gt;FastAPI receives the question, selected mode, hop limit, and optional web-search setting.&lt;/font&gt;" vertex="1">
          <mxGeometry height="185" width="245" x="125" y="247" as="geometry" />
        </mxCell>
        <mxCell id="seq-plan" parent="1" style="html=1;whiteSpace=wrap;fontFamily=Arial;verticalAlign=middle;rounded=1;arcSize=10;fillColor=#ffffff;strokeColor=#64748b;strokeWidth=2;align=center;spacing=10;fontSize=18;fontColor=#0f172a;shadow=0;" value="&lt;b&gt;2. Planning&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#475569&quot;&gt;Builds sub-questions, entity names, topics, and reasoning type for non-strict modes.&lt;/font&gt;" vertex="1">
          <mxGeometry height="126" width="245" x="443" y="271" as="geometry" />
        </mxCell>
